#include <stdio.h>
#include <stdlib.h>
#include <locale.h>
#include <string.h>


void removerVogais (char *str)
{
    int i, j = 0;

    char *semVogais = (char *) malloc(strlen(str) + 1);

    for (i = 0; str[i] != '\0'; i++)
    {
        if (str[i] != 'a' && str[i] != 'e' && str[i] != 'i' && str[i] != 'o' && str[i] != 'u' &&
            str[i] != 'A' && str[i] != 'E' && str[i] != 'I' && str[i] != 'O' && str[i] != 'U')
        {
            semVogais[j++] = str[i];
        }
    }
    semVogais[j] = '\0';
    printf("String sem vogais: %s\n", semVogais);
    free(semVogais);

}



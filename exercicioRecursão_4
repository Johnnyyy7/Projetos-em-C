        /*4. Crie um programa que contenha uma função recursiva para encontrar o menor elemento em um vetor.*/

    int vetor [tamanho], menorNumero;

    printf("Infomre um número: \n");


    for (int i = 0; i < tamanho; i++)
    {
        scanf("%i", &vetor[i]);
    }

    menorNumero = menorNum(vetor, tamanho);

    printf("O menor número é %i\n", menorNumero);

return 0;

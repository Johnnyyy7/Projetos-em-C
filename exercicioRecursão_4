#include <stdio.h>
#include <stdlib.h>
#include <locale.h>
#include <math.h>
#define tamanho 10


int menorNum (int vetor [], int num)
{
    if  (num == 1)
    {
        return vetor[0];
    }
    else
    {
        int menor = menorNum (vetor + 1, num - 1);
        if (vetor[0] < menor)
        {
            return vetor[0];
        }
        else
        {
            return menor;
        }
    }
}



#include <stdio.h>
#include <stdlib.h>
#include <locale.h>

void alocarVetor ()
{
    int *vetor, i;
    vetor = (int*) malloc(5 * sizeof(int));
    if (vetor == NULL)
    {
        printf("Erro ao alocar memória. \n");
        return;
    }
    for (i = 0; i < 5; i++)
    {
        printf("Digite o %i no vetor: ", i + 1);
        scanf("%i", &vetor[i]);
    }
    printf("Números no vetor: \n");
    for (int i = 0; i < 5; i++)
    {
        printf("%i ", vetor[i]);
    }

}

void liberarMemoria (int *vetor)
{
    free(vetor);
    printf("Memória liberada com sucesso.\n");
}


int main()
{


    setlocale(LC_ALL, "Portuguese");


    /*1. Crie um programa que:
    a) Aloque dinamicamente um vetor de 5 números inteiros
    b) Peça para o usuário digitar os 5 números no espaço alocado
    c) Mostre na tela os 5 números
    d) Libere a memória alocada.*/


    int opcao;
    int *vetor = NULL;

    do
    {
        printf("\n\n--- MENU ALOCAÇÃO DINAMîCA DE VETORES ---\n ");
        printf(" 1 - Insira cinco números ao espaço alocado\n");
        printf(" 2 - Liberar memória\n");
        printf(" 0 - Sair\n");
        printf("Escolha uma opção: ");

        scanf("%i", &opcao);

        switch (opcao)
        {
            case 1:
                alocarVetor(vetor);
                break;
            case 2:
                liberarMemoria(vetor);
                break;
            case 0:
                printf("Saindo...");
                break;
            default:
                printf("Opção inválida, tente novamente.\n");
                break;
        }
    } while (opcao != 0);




    return 0;
}
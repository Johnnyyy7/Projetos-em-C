#include <stdio.h>
#include <stdlib.h>
#include <locale.h>


#define Max_Tamanho 50


struct Registro
{
    int matricula;
    char nome [Max_Tamanho];
    int ano_Nascimento;
};


void cadastroAluno (struct Registro *registros, int quantidade)
{
    if (quantidade == 0)
    {
        printf("Nenhum aluno cadastrado.");
    }


    for (int i = 0; i < quantidade; i++)
    {
        printf("\n--- ALUNO %i ---\n", i + 1);


        printf("Matrícula: ");
        scanf("%i", &registros[i].matricula);


        printf("Nome: ");
        scanf(" %[^\n]", registros[i].nome);


        printf("Ano de nascimento: ");
        scanf("%i", &registros[i].ano_Nascimento);
    }
        printf("\nDados cadastrados com sucesso!\n");
}


void exibirDados (struct Registro *registros, int quantidade)
{
    if (quantidade == 0)
    {
        printf("Nenhum aluno cadastrado.");
    }


    printf("\n--- DADOS DOS ALUNOS ---\n");
    for (int i = 0; i < quantidade; i++)
    {
        printf("\nALuno %i: \n", i + 1);
        printf("Matrícula: %i\n", registros[i].matricula);
        printf("Nome: %s\n", registros[i].nome);
        printf("Ano de nascimento: %i\n", registros[i].ano_Nascimento);
    }


    printf("\nLiberando a memória...\n");
    free(registros);
    printf("Memória liberada.\n");


}


int main()
{
    struct Registro *registros;


    setlocale(LC_ALL, "Portuguese");


    /*3. Crie um programa que declare uma estrutura (registro) para o cadastro de alunos:


a) Deverão ser armazenados, para cada aluno: matrıcula, nome (apenas um) e ano de nascimento.
b) Ao início do programa, o usuário deverá informar o número de alunos que serão armazenados
c) O programa devera alocar dinamicamente a quantidade necessária de memória para armazenar os registros dos alunos.
d) O programa deverá pedir ao usuário que entre com as informações dos alunos.
e) Ao final, mostrar os dados armazenados e liberar a memória alocada.
*/


    int opcao;
    int qtdCadastrados;


    printf("Informe quantos alunos deseja armazenar: ");
    scanf("%i", &qtdCadastrados);


    if (qtdCadastrados > 0)
    {
        registros = (struct Registro *) malloc(qtdCadastrados * sizeof(struct Registro));


        if (registros == NULL)
        {
            printf("Memória insuficiente!");
            return 1;
        }


        do
        {
            printf("\n\n--- MENU DO ALUNO ---\n\n");
            printf(" 1 - Cadastrar dados do aluno\n");
            printf(" 2 - Exibir dados e liberar memória\n");
            printf(" 0 - Sair\n");
            printf("Escolha uma opção: ");


            scanf("%i", &opcao);




            switch (opcao)
            {
                case 1:
                    cadastroAluno(registros, qtdCadastrados);
                    break;


                case 2:
                    exibirDados(registros, qtdCadastrados);
                    opcao = 0;
                    break;


                case 0:
                    printf("Saindo...");
                    break;
                default:
                    printf("Opção inválida, tente novamente.\n");
                    break;
            }
        } while (opcao != 0);
    }
    else
    {
        printf("Quantidade inválida de alunos.\n");
    }


    return 0;
}